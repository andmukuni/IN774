NODE_ENV=production
PORT=4000

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://mysql:PASSWORD@84.247.188.115:3624/default

# ── Coolify auto-generated (service: gfl-inventory) ───────────────────────────
