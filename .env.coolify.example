# Coolify environment template — GFL Inventory
# Copy these into Coolify UI → Environment Variables (never commit real secrets)
# Full guide: DEPLOY_COOLIFY.md

NODE_ENV=production
PORT=4000

# ── Database (Coolify-managed MySQL — use INTERNAL hostname) ─────────────────
# Get these from Coolify → MySQL resource → Connection details (internal)
# Prefer DATABASE_URL, or set DB_* individually (DATABASE_URL wins if both set).
# DATABASE_URL=mysql://mysql:PASSWORD@INTERNAL_HOST:3306/default
DB_HOST=
DB_PORT=3306
DB_USER=mysql
DB_PASSWORD=
DB_NAME=default

# ── Public URL (set AFTER first deploy — use Coolify auto-generated URL) ─────
# Must match exactly what you open in the browser (no trailing slash)
APP_URL=https://your-coolify-generated-url.example.com
CORS_ORIGINS=https://your-coolify-generated-url.example.com
TRUST_PROXY=1

# ── Security (generate new values — do not reuse local/dev secrets) ──────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN_SECRET=
ADMIN_API_KEY=

# Required on first deploy if the DB has no admin yet (NODE_ENV=production)
DEFAULT_ADMIN_EMAIL=admin@your-domain.com
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_NAME=GFL Admin

# Optional frontend branding at build time (set as Coolify build arg if needed)
# VITE_COMPANY_NAME=Goodfellow Inventory
