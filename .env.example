# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gfl_inventory

# Optional single URL (overrides DB_* when set — common on Coolify)
# DATABASE_URL=mysql://user:pass@host:3306/gfl_inventory

# API server
PORT=4000

# Security (required in production)
CORS_ORIGINS=http://localhost:5173
APP_URL=http://localhost:5173
TRUST_PROXY=1
AUTH_TOKEN_SECRET=

# Optional alternate admin auth
ADMIN_API_KEY=

# External integration API (managed in Admin → Developer)
# Set TRUST_PROXY=1 when running behind a reverse proxy so IP whitelisting uses the client IP.

# Default admin seed (created on first boot if no admin exists)
DEFAULT_ADMIN_EMAIL=admin@template.dev
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=GFL Admin

# Optional SPA branding at build time
# VITE_COMPANY_NAME=Goodfellow Inventory

# Monitor seed targets (created on boot if missing; passwords required for MySQL)
MONITOR_SEED_APP_URL=https://inv774.goodfellowzm.com
MONITOR_SEED_VOUCHER_APP_URL=https://vm774.goodfellowzm.com
MONITOR_SEED_WEBSITE_URL=http://goodfellow.co.zm
MONITOR_SEED_KENAC_APP_URL=https://goodfellow.kenac.tech
MONITOR_SEED_SAGE200_HOST=102.23.120.197
MONITOR_SEED_SAGE200_PORT=50090
MONITOR_SEED_KENAC_MYSQL_HOST=84.247.188.115
MONITOR_SEED_KENAC_MYSQL_PORT=3306
MONITOR_SEED_KENAC_MYSQL_USER=mysql
MONITOR_SEED_KENAC_MYSQL_DATABASE=default
# MONITOR_SEED_KENAC_MYSQL_PASSWORD=  # falls back to MONITOR_SEED_VOUCHER_MYSQL_PASSWORD
MONITOR_SEED_MYSQL_HOST=84.247.188.115
MONITOR_SEED_MYSQL_PORT=3624
MONITOR_SEED_MYSQL_USER=mysql
MONITOR_SEED_MYSQL_DATABASE=default
# MONITOR_SEED_MYSQL_PASSWORD=
MONITOR_SEED_VOUCHER_MYSQL_HOST=84.247.188.115
MONITOR_SEED_VOUCHER_MYSQL_PORT=3306
MONITOR_SEED_VOUCHER_MYSQL_USER=mysql
MONITOR_SEED_VOUCHER_MYSQL_DATABASE=default
# MONITOR_SEED_VOUCHER_MYSQL_PASSWORD=

# PC presence monitoring — mark devices offline after N minutes without heartbeat
PRESENCE_OFFLINE_THRESHOLD_MINUTES=15
